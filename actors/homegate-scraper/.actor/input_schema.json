{
  "title": "Homegate Scraper Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "listingType": {
      "title": "Listing Type",
      "type": "string",
      "description": "Type of listings to scrape",
      "enum": ["rent", "buy", "both"],
      "default": "both"
    },
    "maxItems": {
      "title": "Max Items",
      "type": "integer",
      "description": "Maximum number of listings to scrape (0 = unlimited)",
      "default": 0,
      "minimum": 0
    }
  },
  "required": ["listingType"]
}
